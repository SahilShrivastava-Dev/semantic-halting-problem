# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
env/
ENV/
.venv/

# Environment Variables (CRITICAL — protects API keys)
.env
.env.local

# IDEs and Editors
.vscode/
.idea/
*.swp
.DS_Store

# Local Model Weights Cache
.hf_cache/

# Logs
*.log

# Backend generated data (runtime outputs)
backend/*.json
backend/*.csv
backend/doc/information_score_test_results.csv

# Experiment artifacts: ignore bulky caches, keep report-critical outputs.
backend/results/**/trajectories/
backend/results/**/judge_cache/
backend/results/**/rows.jsonl

# Exceptions (keep essential project files + the small, version-worthy artifacts)
!backend/test_scenarios.json
!backend/requirements.txt
!backend/.env.example
!backend/data/                       # keep the data directory
!backend/data/test_scenarios.json
!backend/data/scenarios_*.json
!backend/results/**/summary.csv
!backend/results/**/summary.json
!backend/results/**/config_snapshot.json
!backend/results/**/figures/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env.local

# Root level legacy outputs
*.json
*.csv
!test_scenarios.json
!requirements.txt

# Final overrides (later rules win) — keep the version-worthy data + results artifacts.
!backend/data/
!backend/data/*.json
!backend/results/**/summary.json
!backend/results/**/summary.csv
!backend/results/**/config_snapshot.json